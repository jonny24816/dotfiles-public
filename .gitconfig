[init]
	defaultBranch = main
[user]
	email = jonathan.hughes@redwood.com
	name = Jonathan-Hughes_redwood
[push]
    autoSetupRemote = true
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[pull]
	rebase = true
[url "github-jonny24816:jonny24816"]
  insteadOf = git@github.com:jonny24816
[commit]
	template = /Users/jonathanhughes/.gitmessage
[core]
	excludesfile = /Users/jonathanhughes/.gitignore_home
